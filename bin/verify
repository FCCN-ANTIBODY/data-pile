#!/usr/bin/env bash
# Verify a delivered chain: signature against the registered signer, manifest digest,
# hash-linked continuity, and per-block ciphertext hashes. No secrets needed — anyone
# can run this against a public pile.
#
# Usage: bin/verify [--dir DIR] [--source NAME] [--unsigned]
#   --dir       directory holding inbox/ (default: repo root .)
#   --source    feed source name — a Tell you joined (default: atlas)
#   --unsigned  POLICY for unauthenticated ingress (the direct-QR path, feed/direct):
#               do not require a registered signer. Digest + chain + per-block hashes are
#               STILL verified; the acceptance governor (bin/accept) is the gate instead.
#
# Trust env (be explicit, fail closed):
#   DP_ALLOW_UNSIGNED=1   dev bypass of the signature check when ssh-keygen or the signers
#                         file is unavailable (e.g. a constrained dev box). Off by default.

here="$(cd "$(dirname "$0")" && pwd)"
. "$here/lib.sh"
repo="$(cd "$here/.." && pwd)"

dir="."; source="atlas"; signers=""; unsigned=0
while [ $# -gt 0 ]; do
  case "$1" in
    --dir) dir="$2"; shift 2;;
    --source) source="$2"; shift 2;;
    --signers) signers="$2"; shift 2;;
    --unsigned) unsigned=1; shift;;
    *) dp_die "unknown arg: $1";;
  esac
done

inbox="$dir/inbox"
manifest="$inbox/manifest.json"
[ -f "$manifest" ] || dp_die "no manifest at $manifest"

# --- signature over the entries digest ---
[ -n "$signers" ] || signers="$repo/keys/$source.signers"
digest="$(dp_entries_digest "$manifest")"
mdigest="$(jq -r '.head.digest // empty' "$manifest")"
[ "$digest" = "$mdigest" ] || dp_die "manifest digest mismatch (head=$mdigest computed=$digest)"

if [ "$unsigned" = "1" ]; then
  dp_log "policy: unauthenticated source '$source' (direct ingress) — governor is the gate, no signer required"
elif [ "${DP_ALLOW_UNSIGNED:-0}" = "1" ]; then
  dp_log "WARN: signature check skipped (DP_ALLOW_UNSIGNED=1)"
elif ! command -v ssh-keygen >/dev/null 2>&1; then
  dp_die "ssh-keygen not found; cannot verify signature (set DP_ALLOW_UNSIGNED=1 to bypass)"
elif [ ! -f "$signers" ]; then
  dp_die "no registered signer at $signers (set DP_ALLOW_UNSIGNED=1 to bypass)"
else
  sig="$(jq -r '.head.sig // empty' "$manifest")"
  [ -n "$sig" ] || dp_die "manifest head carries no signature"
  tmp="$(mktemp -d)"; trap 'rm -rf "$tmp"' EXIT
  printf '%s' "$sig" | base64 -d > "$tmp/sig"
  printf '%s' "$digest" | ssh-keygen -Y verify -n data-pile -I "$source" \
    -f "$signers" -s "$tmp/sig" >/dev/null \
    || dp_die "signature does NOT verify against $signers"
  # Cross-check the signer fingerprint matches what pile.yml registered.
  want="$(dp_source_signer "$source" "$repo/pile.yml")"
  if [ -n "$want" ]; then
    got="$(awk '{print $2,$3,$4}' "$signers" | ssh-keygen -lf - 2>/dev/null | awk '{print $2}')"
    [ "$got" = "$want" ] || dp_die "signer fingerprint $got != registered $want"
  fi
  dp_log "OK: signature verifies (signer $source)"
fi

# --- hash-linked chain + per-block ciphertext hashes ---
n="$(jq '.entries | length' "$manifest")"
prev="null"
i=0
while [ "$i" -lt "$n" ]; do
  seq="$(jq -r ".entries[$i].seq" "$manifest")"
  block="$(jq -r ".entries[$i].block" "$manifest")"
  this="$(jq -r ".entries[$i].this_hash" "$manifest")"
  ph="$(jq -r ".entries[$i].prev_hash" "$manifest")"
  rp="$(jq -r ".entries[$i].ratchet_pub" "$manifest")"

  [ "$seq" = "$i" ] || dp_die "entry $i out of order (seq=$seq)"
  [ "$ph" = "$prev" ] || dp_die "broken chain at seq $seq (prev_hash=$ph expected=$prev)"
  [ -f "$inbox/$block" ] || dp_die "missing block file $block at seq $seq"
  got="sha256:$(dp_sha256_file "$inbox/$block")"
  [ "$got" = "$this" ] || dp_die "block $block tampered at seq $seq ($got != $this)"
  # ratchet_pub is required for ratchet/signed mode; direct (unsigned) blocks omit it (null).
  if [ -n "$rp" ] && [ "$rp" != "null" ]; then
    printf '%s' "$rp" | grep -Eq '^sha256:[0-9a-f]{64}$' || dp_die "bad ratchet_pub at seq $seq"
  fi

  prev="$this"
  i=$((i+1))
done

dp_log "OK: chain verifies — $n block(s), source '$source'"
echo "verified"
