#!/usr/bin/env bash
# Constitutional acceptance — the pile governs what it keeps. Decrypts a verified Tell
# feed, and for every record judges the answer against THIS pile's per-question
# constitution (questions/<source>/<poll>.json), which the runner authors and may patch
# live. Multichoice option-matches are accepted mechanically; everything else goes to the
# judge (bin/judge, or $DP_JUDGE_CMD). Emits a transparency report tied to the signed
# manifest, so a third party can tie what-was-accepted to the rule in force and the signed
# delivery. Decryption is owner-only (needs the identity).
#
#   bin/govern --dir DIR [--source NAME]
#     DIR holds inbox/ (a pulled feed); identity from PILE_AGE_IDENTITY / DP_IDENTITY_FILE.
#
# Outputs:
#   state/<source>/governed.jsonl              accepted records (owner-side; gitignored)
#   reports/govern-<source>-<stamp>.json       the transparency report (publishable)
set -euo pipefail
here="$(cd "$(dirname "$0")" && pwd)"
. "$here/lib.sh"
repo="$(cd "$here/.." && pwd)"
judge="${DP_JUDGE_CMD:-$here/judge}"

dir=""; source="tell"
while [ $# -gt 0 ]; do
  case "$1" in
    --dir) dir="$2"; shift 2;;
    --source) source="$2"; shift 2;;
    *) dp_die "unknown arg: $1";;
  esac
done
[ -n "$dir" ] || dp_die "specify --dir DIR (a feed with inbox/)"
manifest="$dir/inbox/manifest.json"
[ -f "$manifest" ] || dp_die "no manifest at $manifest"

# Decrypt every block to plaintext tell.digest JSON (owner-only).
plain="$(mktemp -d)"; trap 'rm -rf "$plain"' EXIT
"$here/decrypt" --dir "$dir" --source "$source" --all --out "$plain" >/dev/null

mdigest="$(jq -r '.head.digest' "$manifest")"
signed="$(jq -r '.head.sig != null' "$manifest")"
stamp="$(date -u +%Y%m%dT%H%M%SZ)"
mkdir -p "$repo/state/$source" "$repo/reports"
governed="$repo/state/$source/governed.jsonl"; : > "$governed"
entries="[]"

cons_for() { printf '%s/questions/%s/%s.json' "$repo" "$source" "$1"; }

for f in "$plain"/*.txt; do
  [ -f "$f" ] || continue
  n="$(jq '.records | length' "$f")"; i=0
  while [ "$i" -lt "$n" ]; do
    rec="$(jq -c ".records[$i]" "$f")"; i=$((i+1))
    poll="$(printf '%s' "$rec" | jq -r '.poll // empty')"
    answer="$(printf '%s' "$rec" | jq -r '.answer // empty')"
    cfile="$(cons_for "$poll")"

    if [ ! -f "$cfile" ]; then
      verdict="held"; reason="no constitution for poll '$poll'"; rule="none"
      csha=""; guidance=""
    else
      csha="$(dp_sha256_file "$cfile")"
      guidance="$(jq -r '.guidance // ""' "$cfile")"
      ctype="$(jq -r '.type // "open"' "$cfile")"
      is_opt="$(jq --arg a "$answer" '(.options // []) | index($a) != null' "$cfile")"
      if [ "$ctype" = "multichoice" ] && [ "$is_opt" = "true" ]; then
        verdict="accept"; reason="listed option"; rule="auto"
      else
        v="$(jq -n --argjson rec "$rec" --slurpfile c "$cfile" '{record:$rec, constitution:$c[0]}' | "$judge")"
        verdict="$(printf '%s' "$v" | jq -r '.verdict')"
        reason="$(printf '%s' "$v" | jq -r '.reason')"
        rule="judged"
      fi
    fi

    entries="$(printf '%s' "$entries" | jq \
      --argjson rec "$rec" --arg v "$verdict" --arg r "$reason" --arg rule "$rule" \
      --arg csha "$csha" --arg g "$guidance" '
      . + [{ issue: $rec.issue, poll: $rec.poll, asker: $rec.asker, answer: $rec.answer,
             verdict: $v, reason: $r, rule: $rule, constitution_sha: $csha, guidance: $g }]')"
    if [ "$verdict" = "accept" ]; then
      printf '%s\n' "$(printf '%s' "$rec" | jq -c --arg g "$guidance" '. + {governed:"accept", constitution_guidance:$g}')" >> "$governed"
    fi
  done
done

report="$repo/reports/govern-$source-$stamp.json"
jq -n --arg src "$source" --arg at "$stamp" --arg dg "$mdigest" --argjson signed "$signed" \
      --argjson entries "$entries" '
  { source:$src, generated_at:$at,
    provenance:{ manifest_digest:$dg, signed:$signed },
    counts:( $entries | group_by(.verdict) | map({(.[0].verdict): length}) | add ),
    records:$entries }' > "$report"

dp_log "governed $source: $(jq '.records|length' "$report") record(s) → $report"
echo "$report"
