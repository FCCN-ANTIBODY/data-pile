#!/usr/bin/env bash
# Disclosure. Two modes:
#
#   bin/prove --from N [--dir DIR] [--source NAME]
#       OWNER: derive checkpoint key K_N from the seed and emit a proof bundle to
#       reports/proof-<source>-from-<N>.json. Publishing it lets ANYONE decrypt blocks
#       seq>=N and confirm they match the signed manifest. Forward-only: K_N never
#       reveals blocks before N.
#
#   bin/prove --check FILE [--dir DIR]
#       PUBLIC: given a published proof bundle and a (key-less) checkout, derive forward
#       from the checkpoint, decrypt blocks, and verify each against the signed manifest.
#
# DROP feeds (docs/transfer.md §B "Disclosure parity"): blocks are independent, so the owner
# mode reveals each block's own Kb for seq>=N as `block_keys` instead of a ratchet checkpoint.
# Revealing one block's key derives nothing about any other — strictly MORE isolated than the
# ratchet's forward-only disclosure. The check mode handles either bundle shape.
#
# Owner mode needs the identity (PILE_AGE_IDENTITY / DP_IDENTITY_FILE); check mode needs nothing.

here="$(cd "$(dirname "$0")" && pwd)"
. "$here/lib.sh"

dir="."; source="tell"; from=""; check=""
while [ $# -gt 0 ]; do
  case "$1" in
    --dir) dir="$2"; shift 2;;
    --source) source="$2"; shift 2;;
    --from) from="$2"; shift 2;;
    --check) check="$2"; shift 2;;
    *) dp_die "unknown arg: $1";;
  esac
done
inbox="$dir/inbox"; manifest="$inbox/manifest.json"
[ -f "$manifest" ] || dp_die "no manifest at $manifest"

if [ -n "$check" ]; then
  [ -f "$check" ] || dp_die "no proof bundle at $check"
  cp_from="$(jq -r '.from_seq' "$check")"
  if [ "$(jq 'has("block_keys")' "$check")" = "true" ]; then
    # drop-feed bundle: independent per-block keys, each checked against its own commitment.
    n=0
    for s in $(jq -r '.block_keys | keys_unsorted[]' "$check" | sort -n); do
      kb="$(jq -r --arg s "$s" '.block_keys[$s]' "$check")"
      want="$(jq -r ".entries[$s].ratchet_pub" "$manifest")"
      got="sha256:$(dp_ratchet_pub "$kb")"
      [ "$want" = "$got" ] || dp_die "revealed key fails at seq $s (commitment mismatch)"
      block="$(jq -r ".entries[$s].block" "$manifest")"
      dp_dec "$kb" "$inbox/$block" "-" >/dev/null || dp_die "decrypt failed at seq $s"
      n=$((n+1))
    done
    dp_log "OK: proof verifies $n drop block(s) against the signed manifest"
    echo "proven"
    exit 0
  fi
  kk="$(jq -r '.checkpoint_key' "$check")"
  n="$(jq '.entries | length' "$manifest")"
  s="$cp_from"
  while [ "$s" -lt "$n" ]; do
    want="$(jq -r ".entries[$s].ratchet_pub" "$manifest")"
    got="sha256:$(dp_ratchet_pub "$kk")"
    [ "$want" = "$got" ] || dp_die "checkpoint fails at seq $s (ratchet_pub mismatch)"
    block="$(jq -r ".entries[$s].block" "$manifest")"
    dp_dec "$kk" "$inbox/$block" "-" >/dev/null || dp_die "decrypt failed at seq $s"
    kk="$(dp_ratchet_next "$kk")"
    s=$((s+1))
  done
  dp_log "OK: proof verifies blocks $cp_from..$((n-1)) against the signed manifest"
  echo "proven"
  exit 0
fi

[ -n "$from" ] || dp_die "specify --from N or --check FILE"
idfile=""
if [ -n "${DP_IDENTITY_FILE:-}" ]; then idfile="$DP_IDENTITY_FILE"
elif [ -n "${PILE_AGE_IDENTITY:-}" ]; then idfile="$(mktemp)"; trap 'rm -f "$idfile"' EXIT
  printf '%s\n' "$PILE_AGE_IDENTITY" > "$idfile"
else dp_die "no identity (set PILE_AGE_IDENTITY or DP_IDENTITY_FILE)"; fi

# Drop feed (entries carry `key` files): reveal each block's own Kb for seq>=from.
if [ "$(jq --argjson f "$from" '.entries[$f].key // empty | length > 0' "$manifest")" = "true" ]; then
  n="$(jq '.entries | length' "$manifest")"
  keysjson="{}"
  s="$from"
  while [ "$s" -lt "$n" ]; do
    kf="$(jq -r ".entries[$s].key // empty" "$manifest")"
    [ -n "$kf" ] || dp_die "mixed feed: entry $s has no key file"
    kb="$(age -d -i "$idfile" "$inbox/$kf")" || dp_die "could not unwrap $kf (wrong identity?)"
    keysjson="$(jq -c --arg s "$s" --arg k "$kb" '. + {($s): $k}' <<<"$keysjson")"
    s=$((s+1))
  done
  mkdir -p "$dir/reports"
  bundle="$dir/reports/proof-$source-from-$from.json"
  jq -n --arg src "$source" --argjson from "$from" --argjson keys "$keysjson" \
        --arg dg "$(jq -r '.head.digest' "$manifest")" '
    { source:$src, from_seq:$from, block_keys:$keys, manifest_digest:$dg,
      note:"Publish this to prove the named drop blocks. Anyone: bin/prove --check this-file. Blocks are independent; unnamed blocks stay sealed." }' \
    > "$bundle"
  dp_log "wrote $bundle (publishing it discloses blocks $from.. ; each key opens ONLY its own block)"
  echo "$bundle"
  exit 0
fi

[ -f "$inbox/seed.age" ] || dp_die "no seed.age in $inbox"
k="$(age -d -i "$idfile" "$inbox/seed.age")"
i=0; while [ "$i" -lt "$from" ]; do k="$(dp_ratchet_next "$k")"; i=$((i+1)); done

mkdir -p "$dir/reports"
bundle="$dir/reports/proof-$source-from-$from.json"
jq -n --arg src "$source" --argjson from "$from" --arg key "$k" \
      --arg dg "$(jq -r '.head.digest' "$manifest")" '
  { source:$src, from_seq:$from, checkpoint_key:$key, manifest_digest:$dg,
    note:"Publish this to prove blocks seq>=from_seq. Anyone: bin/prove --check this-file." }' \
  > "$bundle"
dp_log "wrote $bundle (publishing it discloses blocks $from.. ; earlier blocks stay sealed)"
echo "$bundle"
