#!/usr/bin/env bash
# Emit a request-for-pile ("need") from its single source of truth, needs/<id>.json,
# two ways: the registration entry Atlas carries, and the labeled Issue-mirror body
# (with a fenced ```need block anyone can parse). The need.yml workflow uses both —
# it opens the Issue and a registration PR to Atlas. Pull, not push: Atlas never
# writes here; it publishes what's hanging and you pull matches (bin/need-matches).
#
#   bin/need <id> [--entry | --issue]      (default: print both, labeled)
#   REPO   owner/name (default: $GITHUB_REPOSITORY, else parsed from pile.yml repo_url)
set -euo pipefail
here="$(cd "$(dirname "$0")" && pwd)"
. "$here/lib.sh"
repo_root="$(cd "$here/.." && pwd)"

id="${1:?usage: bin/need <id> [--entry|--issue]}"; mode="${2:-both}"
f="$repo_root/needs/$id.json"
[ -f "$f" ] || dp_die "no need at needs/$id.json"
jq -e . "$f" >/dev/null 2>&1 || dp_die "needs/$id.json is not valid JSON"

repo="${REPO:-${GITHUB_REPOSITORY:-}}"
[ -n "$repo" ] || repo="$(awk -F'github.com/' '/repo_url:/{gsub(/[" ]/,"",$2); print $2}' "$repo_root/pile.yml" 2>/dev/null || true)"
[ -n "$repo" ] || repo="OWNER/REPO"
need_url="https://github.com/$repo/blob/main/needs/$id.json"

scope="$(jq -r '.scope // ""' "$f")"; topic="$(jq -r '.topic // ""' "$f")"
text="$(jq -r '.text // ""' "$f")"; terms="$(jq -r '.terms // ""' "$f")"

emit_entry() {
  cat <<YAML
- id: $id
  asker_repo: $repo
  scope: "$scope"
  topic: "$topic"
  terms: "$terms"
  need_url: $need_url
YAML
}
emit_issue() {
  echo "TITLE: need: $text"
  echo "LABELS: need"
  echo "BODY:"
  echo "**Request-for-pile** — no pile yet catches this. If your pile fits, see Atlas's match."
  echo
  echo '```need'
  jq -c --arg repo "$repo" '. + {asker_repo:$repo}' "$f"
  echo '```'
}

case "$mode" in
  --entry) emit_entry;;
  --issue) emit_issue;;
  both) echo "=== Atlas registration entry (append to _data/needs.yml) ==="; emit_entry
        echo; echo "=== Issue mirror ==="; emit_issue;;
  *) dp_die "unknown mode: $mode";;
esac
