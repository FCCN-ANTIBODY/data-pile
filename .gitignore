# Owner-side derived state — regenerated from verified feed blocks by bin/ingest.
# Never authoritative; the feed/** branches are. Keep it out of main.
/state/

# Secrets must never be committed. The age private identity lives in the repo secret
# PILE_AGE_IDENTITY. These patterns are a backstop against accidents.
*.age.key
*.identity
*.priv
key.txt
identity.txt

# Site build output, if a pile renders reports as a site.
_site/
.sass-cache/
.jekyll-cache/
.jekyll-metadata
.bundle/
vendor/
